---
/**
 * Set de iconos de marca. Línea, monocromo (currentColor), extremos redondeados
 * — coherente con el símbolo » (chevron). Reemplazan a los emojis.
 * Uso: <Icon name="web" size={20} class="..." />
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
}
const { name, size = 24, class: className = '', strokeWidth = 1.8 } = Astro.props;

const ICONS: Record<string, string> = {
  // cursos
  web: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3c2.7 3 2.7 15 0 18M12 3c-2.7 3-2.7 15 0 18"/>',
  datos: '<path d="M3.5 20h17"/><path d="M6.5 20v-6M12 20V8M17.5 20v-9"/>',
  movil: '<rect x="7" y="2.5" width="10" height="19" rx="2.5"/><path d="M10.5 18.5h3"/>',
  ia: '<path d="M12 2.5c.6 4.9 3.6 7.9 8.5 8.5-4.9.6-7.9 3.6-8.5 8.5-.6-4.9-3.6-7.9-8.5-8.5 4.9-.6 7.9-3.6 8.5-8.5z"/>',
  // proyectos del motor
  huerto: '<path d="M12 21v-8.5"/><path d="M12 12.5c0-3.3 2.2-5.5 5.5-5.5C17.5 10.3 15.3 12.5 12 12.5z"/><path d="M12 14.5c0-2.8-1.9-4.7-4.7-4.7C7.3 12.6 9.2 14.5 12 14.5z"/>',
  taller: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  liga: '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 21h16"/><path d="M10 15v2.5c0 .8-.6 1.2-1.2 1.5C7.8 19.6 7 20.6 7 21"/><path d="M14 15v2.5c0 .8.6 1.2 1.2 1.5C16.2 19.6 17 20.6 17 21"/><path d="M18 3H6v6a6 6 0 0 0 12 0V3z"/>',
  tuapp: '<path d="M12 3v18M3 12h18M6 6l12 12M18 6L6 18"/>',
  // herramientas
  github: '<path d="M8.6 8 4.6 12l4 4M15.4 8l4 4-4 4"/>',
  stackblitz: '<path d="M13 2.5 5 13.5h6l-2 8 10-11.5h-6z"/>',
  supabase: '<ellipse cx="12" cy="5.5" rx="7" ry="2.8"/><path d="M5 5.5v13c0 1.55 3.13 2.8 7 2.8s7-1.25 7-2.8v-13"/><path d="M5 12c0 1.55 3.13 2.8 7 2.8s7-1.25 7-2.8"/>',
  vercel: '<path d="M12 4 21 19.5H3z"/>',
  // funcional
  lock: '<rect x="4.5" y="10.5" width="15" height="10" rx="2.2"/><path d="M8 10.5V7a4 4 0 0 1 8 0v3.5"/>',
};

const inner = ICONS[name] ?? '';
---
<svg
  class={`icon ${className}`.trim()}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={inner}
/>

<style>
  .icon { display: inline-block; vertical-align: middle; flex: none; }
</style>
