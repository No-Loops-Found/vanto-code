---
import Base from '../layouts/Base.astro';
import Mark from '../components/Mark.astro';
import { serverClient } from '../lib/supabase';
import { MODULES } from '../lib/course-data';
import { CURSOS, cursoById, type Curso } from '../lib/courses';

export const prerender = false;

const supabase = serverClient(Astro.request, Astro.cookies);
const {
  data: { user },
} = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect('/entrar?next=/cuenta');
}

// ── Datos del usuario: inscripciones + progreso + tests ────────────────
const { data: inscRows } = await supabase.from('inscripciones').select('curso');
const { data: progresoRows } = await supabase.from('progreso').select('nivel').eq('superado', true);
const superados = new Set((progresoRows ?? []).map((r) => r.nivel as number));

const { data: quizRows } = await supabase
  .from('quiz_results')
  .select('nivel, aciertos, total, created_at')
  .order('created_at', { ascending: false })
  .limit(8);

// Set de cursos inscritos = inscripciones ∪ 'web' (si hay progreso, por robustez).
const inscritosIds = new Set<string>((inscRows ?? []).map((r) => r.curso as string));
if (superados.size > 0) inscritosIds.add('web');

// Resolvemos cada id contra el catálogo, en el orden del catálogo (Web primero).
const misCursos: Curso[] = CURSOS.filter((c) => inscritosIds.has(c.id));

// ── Estado del curso Web a partir del progreso ─────────────────────────
type EstadoCurso = 'sin empezar' | 'en curso' | 'completado';

const totalWeb = MODULES.length;
const hechosWeb = superados.size;
const pctWeb = Math.round((hechosWeb / totalWeb) * 100);
const estadoWeb: EstadoCurso =
  hechosWeb >= totalWeb ? 'completado' : hechosWeb > 0 ? 'en curso' : 'sin empezar';

// CTA: continuar en el primer nivel no superado; si está completado, repasar.
const siguiente = MODULES.find((m) => !superados.has(m.n)) ?? MODULES[0];
const ctaHrefWeb = estadoWeb === 'completado' ? '/nivel/0' : `/nivel/${siguiente.n}`;
const ctaLabelWeb =
  estadoWeb === 'completado' ? 'Repasar' : estadoWeb === 'en curso' ? 'Continuar' : 'Empezar';

const inscritoWeb = inscritosIds.has('web');
---

<Base title="Mi cuenta · Vanto Code">
  <header class="top">
    <a class="logo" href="/">
      <Mark variant="ink" />
      <span class="wm">vanto<span class="code">·code</span></span>
    </a>
    <nav>
      <a href="/#ruta">La ruta</a>
      <button id="logout" class="linklike" type="button">Salir</button>
    </nav>
  </header>

  <main class="wrap cuenta">
    <p class="eyebrow">Tu cuenta</p>
    <h1>Hola, {user.email}</h1>
    <p class="lead">Estos son los cursos a los que te has apuntado. Tu idea, hacia delante.</p>

    <section>
      <h2 class="sec">Mis cursos</h2>

      {
        misCursos.length === 0 ? (
          <div class="empty">
            <p class="empty-title">Aún no te has apuntado a ningún curso.</p>
            <p class="empty-note">
              Elige tu proyecto y aprende programando lo que de verdad quieres construir.
            </p>
            <a class="cta" href="/#cursos">
              Explora los cursos <span aria-hidden="true">»</span>
            </a>
          </div>
        ) : (
          <div class="cursos">
            {misCursos.map((c) => {
              const isWeb = c.id === 'web';
              const estadoCls = isWeb ? `estado-${estadoWeb.replace(' ', '-')}` : '';
              return (
                <article class={`curso ${estadoCls}`}>
                  <div class="curso-head">
                    <div>
                      <p class="curso-fam">Curso</p>
                      <h3 class="curso-nombre">
                        vanto<span class="mono">·code · {c.destino}</span>
                      </h3>
                    </div>
                    {isWeb && <span class="chip">{estadoWeb}</span>}
                  </div>

                  {isWeb ? (
                    <div class="progreso">
                      <div class="bar">
                        <span style={`width:${pctWeb}%`} />
                      </div>
                      <div class="progreso-meta">
                        <span class="frac">
                          {hechosWeb}
                          <em>/ {totalWeb}</em> niveles
                        </span>
                        <span class="pct">{pctWeb}%</span>
                      </div>
                    </div>
                  ) : (
                    <p class="curso-tagline">{c.tagline}</p>
                  )}

                  <div class="curso-acciones">
                    {isWeb ? (
                      <a class="cta" href={ctaHrefWeb}>
                        {ctaLabelWeb} <span aria-hidden="true">»</span>
                      </a>
                    ) : c.disponible && c.primerNivel != null ? (
                      <a class="cta" href={`/nivel/${c.primerNivel}`}>
                        Empezar <span aria-hidden="true">»</span>
                      </a>
                    ) : (
                      <span class="chip chip--soon">próximamente</span>
                    )}
                    <button class="baja" type="button" data-curso={c.id}>
                      Darme de baja
                    </button>
                  </div>
                </article>
              );
            })}
          </div>
        )
      }
    </section>

    {
      inscritoWeb && (
        <section class="detalle">
          <h2 class="sec">Detalle · vanto·code · Web</h2>
          <ol class="niveles">
            {MODULES.map((m) => (
              <li class={superados.has(m.n) ? 'done' : ''}>
                <span class="marca">{superados.has(m.n) ? '✓' : m.label}</span>
                <a href={`/nivel/${m.n}`}>{m.title}</a>
                {m.tool && <span class="tool">{m.tool}</span>}
              </li>
            ))}
          </ol>
        </section>
      )
    }

    {
      inscritoWeb && quizRows && quizRows.length > 0 && (
        <section class="detalle">
          <h2 class="sec">Tests recientes</h2>
          <ul class="quizzes">
            {quizRows.map((q) => (
              <li>
                <span>Nivel {q.nivel}</span>
                <strong>
                  {q.aciertos}/{q.total}
                </strong>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </main>
</Base>

<style>
  .top { display: flex; align-items: center; justify-content: space-between; max-width: 1120px; margin: 0 auto; padding: 20px 30px; }
  .logo { display: inline-flex; align-items: center; gap: 9px; text-decoration: none; }
  .logo .mark { width: 24px; height: 24px; }
  .wm { font-family: 'Sora', sans-serif; font-weight: 800; font-size: 19px; letter-spacing: -.02em; }
  .code { font-family: 'JetBrains Mono', monospace; font-weight: 500; color: var(--indigo-d); font-size: 14px; }
  nav { display: flex; align-items: center; gap: 18px; font-size: 14px; }
  nav a { text-decoration: none; color: var(--muted); }
  .linklike { background: none; border: none; color: var(--indigo-d); font: inherit; font-weight: 600; cursor: pointer; }

  .cuenta { padding: 24px 30px 90px; max-width: 760px; }
  h1 { font-size: clamp(28px, 5vw, 40px); margin: 10px 0 6px; }
  .lead { color: var(--muted); margin: 0 0 32px; }
  .sec { font-size: 18px; margin: 0 0 14px; }

  section { margin-bottom: 40px; }

  /* Lista de cursos */
  .cursos { display: grid; gap: 16px; }

  /* Tarjeta de curso */
  .curso { background: var(--snow); border: 1px solid var(--line-d); border-radius: 16px; padding: 24px; box-shadow: var(--shadow); }
  .curso-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; }
  .curso-fam { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .04em; text-transform: uppercase; color: var(--muted); margin: 0 0 4px; }
  .curso-nombre { font-family: 'Sora', sans-serif; font-weight: 800; font-size: 22px; letter-spacing: -.02em; }
  .curso-nombre .mono { font-family: 'JetBrains Mono', monospace; font-weight: 500; font-size: 16px; }
  .curso-tagline { color: var(--muted); font-size: 14px; margin: 18px 0 20px; }

  /* Chips (JetBrains Mono) */
  .chip { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 500; letter-spacing: .02em; padding: 5px 10px; border-radius: 999px; border: 1px solid var(--line-d); background: var(--paper-2); color: var(--muted); white-space: nowrap; flex: none; }
  .estado-en-curso .chip { border-color: var(--indigo); color: var(--indigo-d); background: color-mix(in srgb, var(--indigo) 8%, var(--snow)); }
  .estado-completado .chip { border-color: var(--verde); color: var(--verde); background: color-mix(in srgb, var(--verde) 10%, var(--snow)); }
  .chip--soon { background: transparent; }

  /* Progreso del curso Web */
  .progreso { margin: 20px 0 22px; display: grid; gap: 8px; }
  .bar { height: 10px; background: var(--paper-2); border-radius: 999px; overflow: hidden; }
  .bar span { display: block; height: 100%; background: var(--indigo); border-radius: 999px; transition: width .6s var(--ease); }
  .estado-completado .bar span { background: var(--verde); }
  .progreso-meta { display: flex; align-items: baseline; justify-content: space-between; font-size: 14px; }
  .frac { font-family: 'Sora', sans-serif; font-weight: 700; font-size: 20px; }
  .frac em { color: var(--muted); font-style: normal; font-weight: 400; font-size: 14px; margin: 0 4px; }
  .pct { color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: 13px; }

  /* Acciones de la tarjeta */
  .curso-acciones { display: flex; align-items: center; justify-content: space-between; gap: 14px; }

  /* CTA — índigo solo en la acción */
  .cta { display: inline-flex; align-items: center; gap: 8px; background: var(--indigo); color: #fff; text-decoration: none; font-weight: 600; font-size: 15px; padding: 11px 20px; border-radius: 11px; transition: transform .2s var(--ease), background .2s var(--ease); }
  .cta span { transition: transform .2s var(--ease); }
  .cta:hover { background: var(--indigo-d); }
  .cta:hover span { transform: translateX(3px); }

  /* Darse de baja — discreto */
  .baja { background: none; border: none; color: var(--muted); font: inherit; font-size: 13px; cursor: pointer; text-decoration: underline; text-underline-offset: 3px; padding: 6px 2px; }
  .baja:hover { color: var(--rojo); }

  /* Estado vacío */
  .empty { background: var(--snow); border: 1px solid var(--line-d); border-radius: 16px; padding: 34px 28px; box-shadow: var(--shadow); text-align: center; }
  .empty-title { font-family: 'Sora', sans-serif; font-weight: 700; font-size: 19px; margin: 0 0 8px; }
  .empty-note { color: var(--muted); font-size: 14px; margin: 0 auto 22px; max-width: 40ch; }

  /* Detalle: niveles */
  .detalle .sec { color: var(--muted); font-size: 15px; text-transform: none; }
  .niveles { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
  .niveles li { display: flex; align-items: center; gap: 12px; padding: 12px 14px; border: 1px solid var(--line); border-radius: 12px; background: var(--snow); }
  .niveles li.done { border-color: var(--verde); }
  .niveles .marca { font-family: 'JetBrains Mono', monospace; font-size: 12px; width: 26px; height: 26px; display: grid; place-items: center; border-radius: 8px; background: var(--paper-2); color: var(--muted); flex: none; }
  .niveles li.done .marca { background: var(--verde); color: #fff; }
  .niveles a { text-decoration: none; font-weight: 500; flex: 1; }
  .niveles .tool { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--muted); border: 1px solid var(--line); border-radius: 6px; padding: 3px 8px; }

  /* Tests recientes */
  .quizzes { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
  .quizzes li { display: flex; justify-content: space-between; padding: 10px 14px; border: 1px solid var(--line); border-radius: 10px; font-size: 14px; }

  @media (max-width: 520px) {
    .curso-head { flex-direction: column; }
    .curso-acciones { flex-direction: column-reverse; align-items: stretch; }
    .cta { width: 100%; justify-content: center; }
    .baja { text-align: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bar span, .cta, .cta span { transition: none; }
  }
</style>

<script>
  import { browserClient } from '../lib/supabase';

  document.getElementById('logout')?.addEventListener('click', async () => {
    await browserClient().auth.signOut();
    location.assign('/');
  });

  // Darse de baja de un curso.
  document.querySelectorAll<HTMLButtonElement>('.baja').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const curso = btn.dataset.curso;
      if (!curso) return;
      if (!confirm('¿Seguro que quieres darte de baja de este curso?')) return;
      btn.disabled = true;
      const res = await fetch('/api/inscripcion', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ curso }),
      });
      if (res.ok) {
        location.reload();
      } else {
        btn.disabled = false;
        alert('No se pudo completar la baja. Inténtalo de nuevo.');
      }
    });
  });
</script>
