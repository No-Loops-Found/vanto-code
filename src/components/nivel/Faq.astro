---
import type { CollectionEntry } from 'astro:content';

interface Props {
  faq: CollectionEntry<'niveles'>['data']['faq'];
}
const { faq } = Astro.props;
---
<div class="sec-label">Preguntas frecuentes</div>
<div class="faq">
  {
    faq.map((f) => (
      <details>
        <summary>{f.q}</summary>
        <p set:html={f.a} />
      </details>
    ))
  }
</div>
