---
import Mark from '../Mark.astro';

interface Link {
  href: string;
  label: string;
}
interface Props {
  links?: Link[];
  cta?: { href: string; label: string };
}
const {
  links = [
    { href: '#por-que', label: 'Por qué' },
    { href: '#cursos', label: 'Cursos' },
    { href: '#faq', label: 'Preguntas' },
  ],
  cta = { href: '#cursos', label: 'Ver cursos' },
} = Astro.props;
---
<div class="topbar" id="topbar">
  <div class="wrap">
    <a class="tb-logo" href="/">
      <Mark variant="ink" />
      <span class="lw">vanto</span><span class="code">code</span>
    </a>
    <nav class="tb-nav">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href="/entrar" class="tb-auth" id="tbAuth">Entrar</a>
      <a href={cta.href} class="btn indigo">{cta.label} <span class="ar">»</span></a>
    </nav>
  </div>
</div>

<script>
  import { browserClient } from '../../lib/supabase';
  const a = document.getElementById('tbAuth');
  if (a) {
    browserClient()
      .auth.getSession()
      .then(({ data }) => {
        if (data.session) {
          a.textContent = 'Mi cuenta';
          a.setAttribute('href', '/cuenta');
        }
      })
      .catch(() => {});
  }
</script>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(242, 243, 246, .82);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color .3s, background .3s;
  }
  .topbar.scrolled {
    border-bottom-color: var(--line);
    background: rgba(242, 243, 246, .92);
  }
  .topbar .wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .tb-logo { display: flex; align-items: center; gap: 9px; text-decoration: none; }
  .tb-logo :global(.mark) { width: 24px; height: 24px; }
  .tb-logo .lw { font-family: "Sora"; font-weight: 800; font-size: 19px; letter-spacing: -.03em; color: var(--ink); }
  .tb-logo .code { font-family: "JetBrains Mono"; font-weight: 500; font-size: 12px; color: var(--indigo-d); }
  .tb-nav { display: flex; gap: 24px; align-items: center; }
  /* :not(.btn) evita pisar el color blanco del botón CTA (el tipo `a` de
     `.tb-nav a` gana en especificidad al `.btn.indigo` con el scoping de Astro). */
  .tb-nav a:not(.btn) { font-size: 14.5px; color: var(--muted); font-weight: 500; transition: color .15s; text-decoration: none; }
  .tb-nav a:not(.btn):hover { color: var(--ink); }
  @media (max-width: 720px) { .tb-nav a:not(.btn):not(.tb-auth) { display: none; } }
  .tb-auth { font-weight: 600 !important; color: var(--indigo-d) !important; }

  .btn {
    font-family: "Inter"; font-weight: 600; font-size: 14.5px;
    padding: 11px 19px; border-radius: 10px;
    border: 1px solid var(--ink); background: var(--ink); color: #fff;
    cursor: pointer; display: inline-flex; align-items: center; gap: 8px;
    transition: transform .14s var(--ease), box-shadow .14s var(--ease);
  }
  .btn:hover { transform: translateY(-2px); box-shadow: 0 10px 24px -10px rgba(22, 24, 29, .5); }
  .btn.indigo { background: var(--indigo); border-color: var(--indigo); color: #fff; }
  .btn.indigo:hover { box-shadow: 0 12px 28px -10px rgba(75, 73, 240, .6); }
  .btn .ar { transition: transform .18s var(--ease); }
  .btn:hover .ar { transform: translateX(3px); }
  @media (prefers-reduced-motion: reduce) { .btn:hover { transform: none !important; } }
</style>
