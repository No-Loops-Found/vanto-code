---
import Base from '../layouts/Base.astro';
import Topbar from '../components/landing/Topbar.astro';
import Hero from '../components/landing/Hero.astro';
import PorQue from '../components/landing/PorQue.astro';
import Metodo from '../components/landing/Metodo.astro';
import Herramientas from '../components/landing/Herramientas.astro';
import Familia from '../components/landing/Familia.astro';
import Ruta from '../components/landing/Ruta.astro';
import ProjectMotor from '../components/landing/ProjectMotor.astro';
import AppDefiner from '../components/landing/AppDefiner.astro';
import CtaBand from '../components/landing/CtaBand.astro';
import Footer from '../components/landing/Footer.astro';
---

<Base title="Vanto Code — Tu idea, hacia delante.">
  <div class="progress" id="progress"></div>
  <Topbar />
  <Hero />
  <PorQue />
  <Metodo />
  <Familia />
  <Herramientas />
  <Ruta />
  <ProjectMotor />
  <AppDefiner />
  <CtaBand />
  <Footer />
</Base>

<style is:global>
  .progress { position: fixed; top: 0; left: 0; height: 3px; width: 0; background: var(--indigo); z-index: 60; }
</style>

<script>
  /* ===== rotador hero ===== */
  (function () {
    const el = document.getElementById('rot');
    if (!el) return;
    const items = ['la app del tiempo', 'otro clon de Pokémon', 'la lista de tareas nº 47', 'un conversor de monedas'];
    let i = 0;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    el.innerHTML = '<s>' + items[0] + '</s>';
    if (reduce) return;
    el.style.transition = 'opacity .22s ease';
    setInterval(() => {
      i = (i + 1) % items.length;
      el.style.opacity = '0';
      setTimeout(() => {
        el.innerHTML = '<s>' + items[i] + '</s>';
        el.style.opacity = '1';
      }, 220);
    }, 2100);
  })();

  /* ===== reveals ===== */
  const io = new IntersectionObserver(
    (es) => {
      es.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.14 }
  );
  document.querySelectorAll('.reveal').forEach((el, i) => {
    (el as HTMLElement).style.transitionDelay = Math.min(i % 4, 3) * 0.06 + 's';
    io.observe(el);
  });

  /* ===== contadores ===== */
  function animCount(el: HTMLElement) {
    const target = +(el.dataset.count || '0');
    const dur = 1000,
      t0 = performance.now();
    function tick(t: number) {
      const p = Math.min((t - t0) / dur, 1);
      el.textContent = String(Math.round((1 - Math.pow(1 - p, 3)) * target));
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  const cio = new IntersectionObserver(
    (es) => {
      es.forEach((e) => {
        if (e.isIntersecting) {
          animCount(e.target as HTMLElement);
          cio.unobserve(e.target);
        }
      });
    },
    { threshold: 0.6 }
  );
  document.querySelectorAll('[data-count]').forEach((el) => cio.observe(el));

  /* ===== progreso · topbar · hilo de la ruta ===== */
  const progress = document.getElementById('progress')!;
  const topbar = document.getElementById('topbar')!;
  const rutaWrap = document.getElementById('rutaWrap');
  const rutaFill = document.getElementById('rutaFill');
  const mods = [...document.querySelectorAll('.mod')];
  function onScroll() {
    const h = document.documentElement,
      st = h.scrollTop,
      sh = h.scrollHeight - h.clientHeight;
    progress.style.width = (sh > 0 ? (st / sh) * 100 : 0) + '%';
    topbar.classList.toggle('scrolled', st > 10);
    if (rutaWrap && rutaFill) {
      const r = rutaWrap.getBoundingClientRect(),
        vh = window.innerHeight,
        total = r.height,
        passed = Math.min(Math.max(vh * 0.5 - r.top, 0), total);
      rutaFill.style.height = (total > 0 ? (passed / total) * 100 : 0) + '%';
      mods.forEach((m) => {
        m.classList.toggle('seen', m.getBoundingClientRect().top < vh * 0.55);
      });
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
