# Supabase — copia este archivo a .env y rellena con las claves de tu proyecto.
# Panel Supabase → Project Settings → API
PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="tu-anon-key"

# Gemini (Google AI Studio, capa gratuita) — secreto de SERVIDOR (nunca PUBLIC_).
# Se usa en /api/desglose para adaptar el "define tu app" a tu proyecto.
GEMINI_API_KEY="tu-gemini-api-key"
