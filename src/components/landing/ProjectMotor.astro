---
import Icon from '../Icon.astro';
import { FUNDAMENTOS, PROJECTS } from '../../lib/course-data';

const huerto = PROJECTS.huerto;
---
<section class="band dark motor" id="tu-proyecto">
  <div class="wrap">
    <div class="band-head reveal">
      <div class="eyebrow">tu proyecto</div>
      <h2>El mismo temario, con la app que tú elijas.</h2>
      <p>Elige un proyecto de ejemplo (o define el tuyo abajo). La columna de la izquierda —lo que aprendes— no se mueve. Solo cambia el ejemplo con el que lo practicas.</p>
    </div>
    <div class="picker reveal" id="picker">
      {Object.entries(PROJECTS).map(([key, p]) => (
        <button class={`chip ${key === 'huerto' ? 'active' : ''}`} data-key={key} type="button">
          <Icon name={key} size={15} strokeWidth={1.9} /> {p.label}
        </button>
      ))}
    </div>
    <div class="grid-wrap reveal">
      <div class="grid-head"><div>Lo que aprendes</div><div id="projHead">{huerto.head}</div></div>
      <div id="gridRows">
        {FUNDAMENTOS.map((f, idx) => (
          <div class="grow">
            <div class="gcell ra"><span class="ra-code">{f.n}</span><span class="ra-name">{f.name}</span></div>
            <div class="gcell feat" data-idx={idx}>
              <span class="stamp" hidden>TU APP</span><span class="feat-text">{huerto.feats?.[idx]}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="grid-foot">Aprendes <b>lo mismo</b> que en cualquier curso — construyendo tu propia app.</div>
    </div>
  </div>
</section>

<style>
  .band { padding: 78px 0; position: relative; }
  .band.dark { background: var(--ink); color: var(--paper); }
  .band.dark .eyebrow { color: var(--indigo-l); }
  .band-head { max-width: 60ch; margin-bottom: 38px; }
  .band h2 { font-size: clamp(30px, 4.4vw, 46px); margin: 12px 0 14px; max-width: 22ch; color: #fff; }
  .band.dark .band-head p { font-size: 18px; color: #C0C2CB; }
  .reveal { opacity: 0; transform: translateY(26px); transition: opacity .6s var(--ease), transform .6s var(--ease); }
  .reveal.in { opacity: 1; transform: none; }

  .picker { display: flex; flex-wrap: wrap; gap: 9px; margin-bottom: 24px; }
  .chip {
    font-family: "JetBrains Mono"; font-size: 13px; font-weight: 500;
    background: transparent; color: #C9CBD4; border: 1px solid var(--ink-3); border-radius: 999px;
    padding: 9px 15px; cursor: pointer; transition: all .16s var(--ease);
    display: inline-flex; gap: 8px; align-items: center;
  }
  .chip:hover { border-color: var(--indigo); color: #fff; }
  .chip.active { background: var(--indigo); border-color: var(--indigo); color: #fff; }

  .grid-wrap { border: 1px solid var(--ink-3); border-radius: 16px; overflow: hidden; background: var(--ink-2); }
  .grid-head { display: grid; grid-template-columns: minmax(180px, 1fr) minmax(240px, 1.4fr); border-bottom: 1px solid var(--ink-3); }
  .grid-head div { padding: 13px 18px; font-family: "JetBrains Mono"; font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: #8B8E97; }
  .grid-head div:first-child { border-right: 1px solid var(--ink-3); color: var(--indigo-l); }
  .grow { display: grid; grid-template-columns: minmax(180px, 1fr) minmax(240px, 1.4fr); border-bottom: 1px solid #23262e; }
  .grow:last-child { border-bottom: none; }
  .gcell { padding: 13px 18px; font-size: 14.5px; }
  .gcell.ra { border-right: 1px solid var(--ink-3); display: flex; gap: 12px; align-items: flex-start; }
  .ra-code { font-family: "JetBrains Mono"; font-size: 12px; color: var(--indigo-l); font-weight: 600; flex-shrink: 0; padding-top: 2px; width: 26px; }
  .ra-name { color: #E7E8EE; font-weight: 500; }
  .gcell.feat { color: #B6B9C2; }
  .gcell.feat.soft { color: #767986; font-style: italic; }
  /* OJO: animar la celda (item de grid) con transform hace que Chrome la
     dimensione al contenido y se encoja. Se anima el span interior. */
  .gcell.feat.mark .feat-text { display: inline-block; animation: remark .45s var(--ease); }
  @keyframes remark { 0% { opacity: 0; transform: translateX(10px); } 100% { opacity: 1; transform: none; } }
  .stamp { display: inline-block; font-family: "JetBrains Mono"; font-size: 10px; color: var(--indigo-l); border: 1px solid var(--indigo); border-radius: 4px; padding: 1px 5px; margin-right: 8px; vertical-align: middle; }
  .stamp[hidden] { display: none; }
  .grid-foot { padding: 14px 18px; font-family: "JetBrains Mono"; font-size: 12px; color: #8B8E97; background: #191c22; border-top: 1px solid var(--ink-3); }
  .grid-foot b { color: var(--indigo-l); }

  @media (max-width: 560px) {
    .grid-head, .grow { grid-template-columns: 1fr; }
    .gcell.ra { border-right: none; border-bottom: 1px solid var(--ink-3); }
    .grid-head div:first-child { border-right: none; }
  }
  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1 !important; transform: none !important; } }
</style>

<script>
  import { FUNDAMENTOS, PROJECTS } from '../../lib/course-data';
  import type { AnalyzeResult } from '../../lib/classify';

  const projHead = document.getElementById('projHead');
  const cells = Array.from(document.querySelectorAll<HTMLElement>('#gridRows .gcell.feat'));

  let tuappData: AnalyzeResult | null = null;
  let tuappHead = PROJECTS.tuapp.head;

  // Solo intercambia texto/estado de celdas ya renderizadas en servidor.
  function render(key: string, anim: boolean) {
    const p = PROJECTS[key];
    if (projHead) projHead.textContent = key === 'tuapp' ? tuappHead : p.head;
    FUNDAMENTOS.forEach((f, idx) => {
      const cell = cells[idx];
      if (!cell) return;
      let feat: string;
      let soft = false;
      if (p.feats) {
        feat = p.feats[idx];
      } else if (tuappData) {
        const cls = tuappData.byFund[f.id];
        if (cls && cls.length) {
          feat = cls.join(' · ');
        } else if (f.struct) {
          feat = 'Se practica igual, forma parte de la base.';
          soft = true;
        } else {
          feat = 'Aún no aparece en tus funciones — lo verás en el curso.';
          soft = true;
        }
      } else {
        feat = 'Define tu app abajo para rellenar esta columna.';
        soft = true;
      }
      const textEl = cell.querySelector('.feat-text');
      if (textEl) textEl.textContent = feat;
      cell.classList.toggle('soft', soft);
      const stamp = cell.querySelector('.stamp') as HTMLElement | null;
      if (stamp) stamp.hidden = key !== 'tuapp';
      if (anim) {
        cell.classList.remove('mark');
        void cell.offsetWidth; // reinicia la animación
        cell.classList.add('mark');
      }
    });
  }

  function activate(key: string) {
    document.querySelectorAll('#picker .chip').forEach((c) => c.classList.remove('active'));
    document.querySelector(`#picker .chip[data-key="${key}"]`)?.classList.add('active');
  }

  document.querySelectorAll<HTMLButtonElement>('#picker .chip').forEach((b) => {
    b.addEventListener('click', () => {
      const key = b.dataset.key || 'huerto';
      activate(key);
      render(key, true);
    });
  });

  document.addEventListener('vanto:defined', (e) => {
    const detail = (e as CustomEvent<{ name: string; data: AnalyzeResult }>).detail;
    tuappData = detail.data;
    tuappHead = detail.name;
    activate('tuapp');
    render('tuapp', true);
  });
</script>
