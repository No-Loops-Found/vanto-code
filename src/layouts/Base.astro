---
// Tokens + base globales inline en el <head>: garantizado en todas las páginas
// (el import por JS de CSS global no llegaba a las páginas estáticas con este bundling).
import globalCss from '../styles/global.css?raw';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Vanto Code — aprende a programar construyendo algo que te sirva. Tu idea, hacia delante.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <style is:inline set:html={globalCss}></style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
